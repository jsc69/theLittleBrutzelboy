  "name": "setPartFootprint",
  "symbol": "script_38",
  "description": "sets the part for footprint in array partFootprint\nand sets variable PartFootprint",
  "variables": {
    "V0": {
      "id": "V0",
      "name": "placeNo",
      "passByReference": true
    },
