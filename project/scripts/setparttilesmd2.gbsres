    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "Components:\n-Resistors\n00 = 151 - 150\n01 = 153 - 15k\n02 = 155 - 1500k\n03 = 361 - 360\n04 = 363 - 36k\n05 = 365 - 3600k\n06 = 561 - 560\n*07 = 563 - 56k\n08 = 565 - 5600k\n09 = 271 - 270\n10 = 272 -2,7k\n11 = 273 - 27k\n*12 = 331 - 330\n13 = 332 - 3,3k\n14 = 333 - 33k\n15 = 471 - 470\n16 = 472 - 4,7k\n*17 = 473 - 47k\n- Capacitors\n18 = 10pF\n19 = 47pF\n20 = 56pF\n21 = 100pF\n22 = 2,2nF\n*23 = 10nF\n24 = 47nF\n25 = 56nF\n26 = 220nF\n*27 = 10uF\n28 = 22uF\n29 = 47uF\n30 = 56uF\n31 = 100uF\n32 = 470uF\n- Diodes\n33 = 1N4007\n34 = 1N4001\n35 = 1N4004\n- ICs\n36 = MC34063A\n37 = ATTINY13A\n*38 = NE555\n- extra\n*39 = LED\n",
        "__collapse": true
      },
